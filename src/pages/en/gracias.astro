---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';
import { CONTACT } from '../../lib/contact';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title="Consultation Requested"
  description={t('site_description')}
  lang={lang}
>
  <section class="min-h-screen dot-grid flex items-center justify-center px-4 py-32">
    <div class="w-full max-w-2xl mx-auto">

      <!-- Success icon -->
      <div class="flex justify-center mb-10 hero-animate">
        <div class="relative">
          <div
            class="w-24 h-24 rounded-full flex items-center justify-center"
            style="background: rgba(76,175,80,0.1); border: 2px solid rgba(76,175,80,0.35);"
          >
            <svg
              width="40" height="40" viewBox="0 0 24 24" fill="none"
              stroke="#4CAF50" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round"
            >
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div class="pulse-ring absolute inset-0 rounded-full"></div>
        </div>
      </div>

      <!-- Heading + separator -->
      <div class="text-center hero-animate hero-delay-1">
        <h1 class="font-serif font-bold text-4xl lg:text-5xl mb-4" style="color: #FAF6EE;">
          {t('gracias_heading')}
        </h1>
        <p class="text-lg mb-6" style="color: #9B9080;">{t('gracias_sub')}</p>
        <span class="gold-sep"></span>
      </div>

      <!-- What's next steps -->
      <div class="mt-12 mb-10 hero-animate hero-delay-2">
        <p class="section-label text-center mb-6">{t('gracias_steps_label')}</p>
        <div class="grid gap-3">

          <div class="flex items-start gap-4 p-5 rounded-lg service-card" style="background: #1C1C1C;">
            <div
              class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
              style="background: rgba(201,160,39,0.15); border: 1px solid rgba(201,160,39,0.4);"
            >
              <span class="font-bold text-sm" style="color: #C9A027;">1</span>
            </div>
            <div>
              <p class="font-semibold text-sm mb-1" style="color: #FAF6EE;">{t('gracias_step1_title')}</p>
              <p class="text-sm leading-relaxed" style="color: #9B9080;">{t('gracias_step1_desc')}</p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-5 rounded-lg service-card" style="background: #1C1C1C;">
            <div
              class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
              style="background: rgba(201,160,39,0.15); border: 1px solid rgba(201,160,39,0.4);"
            >
              <span class="font-bold text-sm" style="color: #C9A027;">2</span>
            </div>
            <div>
              <p class="font-semibold text-sm mb-1" style="color: #FAF6EE;">{t('gracias_step2_title')}</p>
              <p class="text-sm leading-relaxed" style="color: #9B9080;">{t('gracias_step2_desc')}</p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-5 rounded-lg service-card" style="background: #1C1C1C;">
            <div
              class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
              style="background: rgba(201,160,39,0.15); border: 1px solid rgba(201,160,39,0.4);"
            >
              <span class="font-bold text-sm" style="color: #C9A027;">3</span>
            </div>
            <div>
              <p class="font-semibold text-sm mb-1" style="color: #FAF6EE;">{t('gracias_step3_title')}</p>
              <p class="text-sm leading-relaxed" style="color: #9B9080;">{t('gracias_step3_desc')}</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Immediate contact options -->
      <div
        class="p-6 rounded-lg text-center mb-10 hero-animate hero-delay-3"
        style="background: #1C1C1C; border: 1px solid #2A2A2A;"
      >
        <p class="text-sm font-medium mb-5" style="color: #9B9080;">{t('gracias_contact_alt')}</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href={CONTACT.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary flex items-center justify-center gap-2"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.083.534 4.037 1.468 5.741L.057 23.882a.5.5 0 00.621.606l6.249-1.635A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.893a9.899 9.899 0 01-5.047-1.381l-.362-.215-3.709.972.99-3.617-.235-.374A9.86 9.86 0 012.107 12C2.107 6.53 6.53 2.107 12 2.107c5.47 0 9.893 4.423 9.893 9.893S17.47 21.893 12 21.893z"/>
            </svg>
            {t('gracias_contact_wa')}
          </a>
          <a href={CONTACT.phoneUrl} class="btn-outline flex items-center justify-center gap-2">
            <svg
              width="16" height="16" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.37 9.81 19.79 19.79 0 01.31 1.18 2 2 0 012.3 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.06 6.06l1.27-.76a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            {t('gracias_contact_call')}
          </a>
        </div>
      </div>

      <!-- Back to home -->
      <div class="text-center hero-animate hero-delay-4">
        <a href="/en/" class="btn-outline">
          ← {t('gracias_back')}
        </a>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .pulse-ring {
    animation: pulse-anim 2.2s ease-out infinite;
    border: 2px solid rgba(76, 175, 80, 0.5);
  }

  @keyframes pulse-anim {
    0%   { transform: scale(1);   opacity: 0.7; }
    100% { transform: scale(1.6); opacity: 0; }
  }
</style>
