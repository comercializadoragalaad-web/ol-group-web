---
import type { Lang } from '../../i18n';
import { useTranslations } from '../../i18n';
import SectionHeading from '../ui/SectionHeading.astro';
import ServiceCard from '../ui/ServiceCard.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const iconColor = 'color: #C9A027;';
const iconStroke = `fill="none" stroke="#C9A027" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"`;

const services = [
  {
    key: 'contabilidad',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" ${iconStroke}><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="9" x2="16" y2="9"/><line x1="8" y1="13" x2="14" y2="13"/></svg>`,
  },
  {
    key: 'auditoria',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" ${iconStroke}><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  },
  {
    key: 'asesoria',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" ${iconStroke}><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
  },
  {
    key: 'formulacion',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" ${iconStroke}><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>`,
  },
  {
    key: 'aduanas',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" ${iconStroke}><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
  },
] as const;
---

<section id="servicios" class="py-20 lg:py-28" style="background: #FAF6EE;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="mb-16">
      <SectionHeading
        label={t('servicios_label')}
        heading={t('servicios_heading')}
        align="center"
        dark={true}
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((svc, i) => (
        <ServiceCard
          icon={svc.icon}
          titulo={t(`servicios_${svc.key}_titulo` as any)}
          descripcion={t(`servicios_${svc.key}_desc` as any)}
          delay={i % 3 as 0 | 1 | 2 | 3 | 4}
        />
      ))}
    </div>

  </div>
</section>
