---
import type { Lang } from '../../i18n';
import { useTranslations } from '../../i18n';
import SectionHeading from '../ui/SectionHeading.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const iconStroke = `fill="none" stroke="#C9A027" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"`;

const features = [
  {
    key: '1',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" ${iconStroke}><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
  {
    key: '2',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" ${iconStroke}><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  },
  {
    key: '3',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" ${iconStroke}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    key: '4',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" ${iconStroke}><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  },
] as const;
---

<section id="por-que" class="py-20 lg:py-28" style="background: #0A0A0A;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Features -->
      <div>
        <div class="mb-12">
          <SectionHeading
            label={t('porque_label')}
            heading={t('porque_heading')}
            align="left"
            dark={false}
          />
        </div>

        <div class="space-y-6">
          {features.map((f, i) => (
            <div class={`feature-item reveal reveal-delay-${i + 1}`}>
              <div class="flex items-start gap-4">
                <div
                  class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5"
                  style="background: rgba(201,160,39,0.12);"
                >
                  <Fragment set:html={f.icon} />
                </div>
                <div>
                  <h3 class="font-sans font-semibold text-base mb-1.5" style="color: #FAF6EE;">
                    {t(`porque_${f.key}_titulo` as any)}
                  </h3>
                  <p class="text-sm leading-relaxed" style="color: #9B9080;">
                    {t(`porque_${f.key}_desc` as any)}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Image -->
      <div class="hidden lg:flex justify-center items-center reveal reveal-delay-2">
        <div class="relative">
          <!-- Glow orbs -->
          <div class="absolute -top-6 -left-6 w-28 h-28 rounded-full opacity-15" style="background: radial-gradient(circle, #C9A027, transparent);"></div>
          <div class="absolute -bottom-6 -right-6 w-20 h-20 rounded-full opacity-15" style="background: radial-gradient(circle, #C9A027, transparent);"></div>

          <div
            class="rounded-lg overflow-hidden relative"
            style="width: 400px; height: 500px; border: 1px solid #2A2A2A;"
          >
            <img
              src="/images/Jaguar con pirámide Tikal.png"
              alt="OL Group — Raíces guatemaltecas, visión financiera global"
              class="w-full h-full object-cover"
              loading="lazy"
              width="400"
              height="500"
            />
            <!-- Overlay gradient -->
            <div
              class="absolute inset-0"
              style="background: linear-gradient(to top, rgba(10,10,10,0.6) 0%, transparent 60%);"
            ></div>
          </div>

          <!-- Stats badge -->
          <div
            class="absolute top-6 right-6 p-4 rounded-lg text-center"
            style="background: rgba(10,10,10,0.9); border: 1px solid rgba(201,160,39,0.35);"
          >
            <div class="font-serif font-bold text-2xl" style="color: #C9A027;">98%</div>
            <div class="text-xs mt-0.5" style="color: #9B9080;">{t('porque_stat')}</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
